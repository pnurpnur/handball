generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Season {
  id        Int      @id @default(autoincrement())
  name      String
  matches   Match[]
  createdAt DateTime @default(now())
}

model Team {
  id          Int       @id // handball.no lag-ID
  name        String
  shortName   String?
  clubName    String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  matches     Match[]
}

model Match {
  id              String    @id // handball.no matchid
  teamId          Int
  team            Team      @relation(fields: [teamId], references: [id])
  seasonId        Int?
  season          Season?   @relation(fields: [seasonId], references: [id])

  tournament      String
  date            DateTime?
  homeTeam        String
  awayTeam        String
  homeScore       Int?
  awayScore       Int?
  isPlayed        Boolean   @default(false)
  venue           String?

  emreInSquad     Boolean   @default(false)
  emreStats       EmreStats?

  scrapedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([teamId])
  @@index([date])
  @@index([seasonId])
}

model EmreStats {
  id          Int     @id @default(autoincrement())
  matchId     String  @unique
  match       Match   @relation(fields: [matchId], references: [id])

  goals       Int     @default(0)
  sevenMeter  Int     @default(0)
  yellowCards Int     @default(0)
  twoMinutes  Int     @default(0)
  redCards    Int     @default(0)
}

model ScrapeLog {
  id        Int       @id @default(autoincrement())
  teamId    Int?
  status    String    // "success" | "error"
  message   String?
  matchesUpdated Int  @default(0)
  duration  Int?      // ms
  createdAt DateTime  @default(now())
}
